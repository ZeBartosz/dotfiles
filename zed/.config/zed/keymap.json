[
	{
		"context": "Editor && VimControl && vim_mode == normal && !menu",
		"bindings": {
			"ctrl-e": "file_finder::Toggle",

			// +LSP
			"c r": "editor::Rename",
			"g d": "editor::GoToDefinition",
			"g D": "editor::GoToDefinitionSplit",
			"g i": "editor::GoToImplementation",
			"g I": "editor::GoToImplementationSplit",
			"g t": "editor::GoToTypeDefinition",
			"g T": "editor::GoToTypeDefinitionSplit",
			"g r": "editor::FindAllReferences",

			"g l r": "editor::RestartLanguageServer",

			"f k": "editor::Hover",
			"f j": "editor::ToggleCodeActions",

			"] d": "editor::GoToDiagnostic",
			"[ d": "editor::GoToPreviousDiagnostic",

			// TODO: Go to next/prev error
			"] e": "editor::GoToDiagnostic",
			"[ e": "editor::GoToPreviousDiagnostic",

			// Diagnostic
			"space x x": "diagnostics::Deploy",

			// +Git
			// Git prev/next hunk
			"f g": "git::Diff",
			"f s": "git::ToggleStaged",
			"f r": "git::Restore",
			"f ]": "editor::GoToHunk",
			"f [": "editor::GoToPreviousHunk",

			"tab": "editor::Tab",
			"shift-tab": "editor::Backtab",
		},
	},
	// visual, visual line & visual block modes
	{
		"context": "(VimControl && !menu)",
		"bindings": {
			"space": null, // Disable the default action vim::WrappingRight
		},
	},
	// Workspace
	{
		"context": "Workspace",
		"bindings": {
			// File Finder
			"ctrl-e": "file_finder::Toggle",

			// Git
			"alt-p": [
				"task::Spawn",
				{ "task_name": "GitPR", "reveal_target": null },
			],
			"alt-o": [
				"task::Spawn",
				{ "task_name": "GitRepo", "reveal_target": null },
			],
			"alt-g": "git_panel::ToggleFocus",
			"alt-shift-g": [
				"task::Spawn",
				{ "task_name": "LazyGit", "reveal_target": "center" },
			],
			"ctrl-alt-a": "terminal_panel::ToggleFocus",
			"alt-shift-a": [
				"task::Spawn",
				{ "task_name": "opencode", "reveal_target": "dock" },
			],
			// Dock Toggle
			"alt-e": "project_panel::ToggleFocus",
			"alt-b": "workspace::ToggleRightDock",
			"alt-a": "agent::ToggleFocus",
			"alt-x": "zed::Extensions",
			"ctrl-p": "command_palette::Toggle",
		},
	},
	// Teerminal
	{
		"context": "Terminal",
		"bindings": {
			// "ctrl-/": "workspace::ToggleBottomDock",
			"alt-j": ["workspace::SendKeystrokes", "down"],
			"alt-k": ["workspace::SendKeystrokes", "up"],
		},
	},
	{
		"context": "vim_mode == normal",
		"bindings": {
			"alt-/": "assistant::InlineAssist",
		},
	},
	{ "context": "Editor", "bindings": { "ctrl-w": "pane::CloseActiveItem" } },
]
